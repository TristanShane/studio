
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    match /users/{userId} {
      allow get, write: if isOwner(userId);
    }

    match /households/{householdId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      // Only the owner can update household settings or delete the base.
      // resource.data.ownerId must match the authenticated user UID.
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid; 
    }

    match /households/{householdId}/joinRequests/{userId} {
      // User can create their own request
      allow create: if isOwner(userId);
      // Owner of household or the user themselves can read/manage the request
      allow get, delete: if isSignedIn() && (isOwner(userId) || get(/databases/$(database)/documents/households/$(householdId)).data.ownerId == request.auth.uid);
      allow list, update: if isSignedIn() && get(/databases/$(database)/documents/households/$(householdId)).data.ownerId == request.auth.uid;
    }

    // Default: no access to anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
