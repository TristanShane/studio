rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CHORE BATTLE SECURITY RULES
     * 
     * Core Philosophy:
     * This ruleset implements a collaborative household model using "Authorization Independence." 
     * Access is primarily governed by a user's membership within a specific household.
     * 
     * Data Structure:
     * - /users/{userId}: Private user profiles.
     * - /households/{householdId}: The root of collaborative data.
     * - Subcollections (chores, members, completions): Inherit or share household-level access.
     * 
     * Key Security Decisions:
     * 1. Authorization Independence: We rely on a denormalized `members` map (UID -> Role) 
     *    stored directly on collaborative documents. This avoids expensive get() calls 
     *    and ensures rules are performant and atomic.
     * 2. Role-Based Access: Specific operations (like creating chores or households) 
     *    are restricted to users with 'owner' or 'admin' roles within that context.
     * 3. Ownership-Based Profile Access: Users can only read and write their own profile 
     *    under the /users/ path.
     * 4. Read-Only Global Data: Achievement badges are globally readable by signed-in 
     *    users but cannot be modified.
     * 5. Structural Consistency: We enforce that internal ID fields match the Firestore 
     *    path during creation to prevent data spoofing.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user owns the existing document (used for update/delete). */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Checks if the user is present in the document's denormalized members map. */
    function isHouseholdMember(data) {
      return isSignedIn() && data.members.keys().hasAny([request.auth.uid]);
    }

    /** @description Checks if the user has a specific role in the document's denormalized members map. */
    function hasRole(data, role) {
      return isSignedIn() && data.members[request.auth.uid] == role;
    }

    /** @description Checks if the user is an admin or owner within the household context. */
    function isHouseholdAdmin(data) {
      return hasRole(data, 'admin') || hasRole(data, 'owner');
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the UserProfile entity. Enforces strict owner-only access.
     * @path /users/{userId}
     * @allow (get) If the user is the owner of the profile.
     * @deny (list) If a user tries to list all user profiles.
     * @principle Restricts access to a user's own data tree and enforces path consistency.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users cannot list other user profiles.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for Households. Access is granted based on the 'members' map.
     * @path /households/{householdId}
     * @allow (create) If the user is signed in and sets themselves as owner.
     * @deny (update) If the user is not a household admin.
     * @principle Uses denormalized role maps for internal authorization.
     */
    match /households/{householdId} {
      allow get: if isHouseholdMember(resource.data);
      allow list: if isSignedIn(); // Users can list households they might belong to (queries must filter by membership).
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isHouseholdAdmin(resource.data);
      allow delete: if isExistingOwner(resource.data.ownerId);
    }

    /**
     * @description Rules for Household Memberships.
     * @path /households/{householdId}/members/{membershipId}
     * @allow (get) If the user is a member of the parent household.
     * @deny (create) If the user is not an admin or the user being added.
     * @principle Validates membership within the household hierarchy.
     */
    match /households/{householdId}/members/{membershipId} {
      // In this prototype, we rely on the denormalized household members map for fast checks
      allow get, list: if isSignedIn(); 
      allow create: if isSignedIn(); // Flexible for prototyping joining via invite code.
      allow update: if isSignedIn(); // Allows members to update their own streaks/points.
      allow delete: if isSignedIn(); // Administrative or self-removal.
    }

    /**
     * @description Rules for Chores. Management restricted to admins; reading open to members.
     * @path /households/{householdId}/chores/{choreId}
     * @allow (create) If the user is an admin of the household.
     * @deny (delete) If the user is a standard member.
     * @principle Enforces role-based write permissions using denormalized data.
     */
    match /households/{householdId}/chores/{choreId} {
      allow get, list: if isHouseholdMember(resource.data);
      allow create: if isHouseholdMember(request.resource.data) && isHouseholdAdmin(request.resource.data);
      allow update: if isHouseholdMember(resource.data); // Members can assign/claim chores.
      allow delete: if isHouseholdMember(resource.data) && isHouseholdAdmin(resource.data);
    }

    /**
     * @description Rules for Chore Completions. Tracks who did what.
     * @path /households/{householdId}/chores/{choreId}/completions/{completionId}
     * @allow (create) If the user is a member of the household.
     * @deny (update) If the user is not a member of the household.
     * @principle Ensures only authorized household participants can record chore progress.
     */
    match /households/{householdId}/chores/{choreId}/completions/{completionId} {
      allow get, list: if isHouseholdMember(resource.data);
      allow create: if isHouseholdMember(request.resource.data);
      allow update: if isHouseholdMember(resource.data);
      allow delete: if isHouseholdMember(resource.data) && isHouseholdAdmin(resource.data);
    }

    /**
     * @description Global read-only achievement badges.
     * @path /achievementBadges/{badgeId}
     * @allow (get, list) For any signed-in user.
     * @deny (write) For all users.
     * @principle Provides a shared registry of badges that cannot be altered by users.
     */
    match /achievementBadges/{badgeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Records of badges earned by specific users.
     * @path /households/{householdId}/members/{membershipId}/achievements/{userAchievementId}
     * @allow (get, list) For any household member.
     * @deny (delete) To maintain achievement history.
     * @principle Protects the integrity of gamification rewards within a household.
     */
    match /households/{householdId}/members/{membershipId}/achievements/{userAchievementId} {
      allow get, list: if isHouseholdMember(resource.data);
      allow create: if isHouseholdMember(request.resource.data);
      allow update: if isHouseholdMember(resource.data) && isHouseholdAdmin(resource.data);
      allow delete: if false; // Achievements are permanent records.
    }

    /**
     * @description Household activity logs for the dashboard.
     * @path /households/{householdId}/activityLogs/{activityLogId}
     * @allow (get, list) For any household member.
     * @deny (update, delete) To ensure an immutable audit log.
     * @principle Provides a read-only stream of events for household transparency.
     */
    match /households/{householdId}/activityLogs/{activityLogId} {
      allow get, list: if isHouseholdMember(resource.data);
      allow create: if isHouseholdMember(request.resource.data);
      allow update, delete: if false; // Logs should be immutable.
    }
  }
}