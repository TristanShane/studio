
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents an individual user of the Chore Battle application.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "currentHouseholdId": { "type": "string" }
      },
      "required": ["id", "name", "email"]
    },
    "Household": {
      "title": "Household",
      "type": "object",
      "description": "A group managing chores together.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "inviteCode": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "inviteCode", "ownerId", "createdAt"]
    },
    "JoinRequest": {
      "title": "JoinRequest",
      "type": "object",
      "description": "A request from a user to join a specific household using a battle code.",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "requestedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "status"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Private user profile."
        }
      },
      {
        "path": "/households/{householdId}",
        "definition": {
          "entityName": "Household",
          "schema": { "$ref": "#/backend/entities/Household" },
          "description": "Household root document."
        }
      },
      {
        "path": "/households/{householdId}/joinRequests/{userId}",
        "definition": {
          "entityName": "JoinRequest",
          "schema": { "$ref": "#/backend/entities/JoinRequest" },
          "description": "Requests to join a household."
        }
      }
    ]
  }
}
